# Nunca guardes una clave real en Git. El instalador crea .env de forma local.
OPENAI_REALTIME_API_KEY=
OPENCLAW_GATEWAY_TOKEN=reemplazar-por-un-token-aleatorio

# Canal estable: al arrancar, los scripts comprueban si latest ha cambiado.
OPENCLAW_IMAGE=ghcr.io/andreuserrasastre/tipi-openclaw:latest
TIPI_VOICE_IMAGE=ghcr.io/andreuserrasastre/tipi-voice:latest

TZ=Europe/Madrid
TIPI_HOST_ROOT=/
TIPI_GATEWAY_URL=ws://127.0.0.1:18789
TIPI_SESSION_KEY=agent:main:tipi-voice
TIPI_WAKE_WORDS=tipi,tipy,tip,tippi,tippy
TIPI_IDLE_TIMEOUT_SECONDS=5
TIPI_INPUT_DEVICE=
TIPI_OUTPUT_DEVICE=
TIPI_INPUT_SAMPLE_RATE=48000
TIPI_OUTPUT_SAMPLE_RATE=48000
TIPI_OUTPUT_CHANNELS=2
TIPI_VAD_MODE=3
TIPI_BARGE_IN=false
TIPI_OUTPUT_ECHO_GUARD_SECONDS=0.8
TIPI_REALTIME_SPEAKER_VOICE=cedar
TIPI_REALTIME_NOISE_REDUCTION=far_field
TIPI_REALTIME_TRANSCRIPTION_LANGUAGE=es
TIPI_REALTIME_TRANSCRIPTION_PROMPT=Conversación presencial en español de España o catalán sobre Tipi, tipdata, Andreu y OpenClaw. Conserva el idioma hablado y no inventes idiomas.
TIPI_LOG_LEVEL=INFO
TIPI_LOG_DIR=data/logs
TIPI_HEALTH_FILE=data/voice/tipi-voice.health

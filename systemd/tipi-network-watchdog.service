[Unit]
Description=Tipi - recuperacion tras volver Internet
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=/usr/local/libexec/tipi-network-watchdog
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
RuntimeDirectory=tipi-network-watchdog
RuntimeDirectoryMode=0755
ReadWritePaths=/run/tipi-network-watchdog

[Install]
WantedBy=multi-user.target

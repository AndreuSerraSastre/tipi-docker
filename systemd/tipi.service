[Unit]
Description=Tipi - OpenClaw y voz local
Wants=network-online.target
After=network-online.target docker.service sound.target
Requires=docker.service

[Service]
Type=oneshot
User=__TIPI_USER__
Group=__TIPI_GROUP__
WorkingDirectory=__TIPI_DIR__
ExecStart=__TIPI_DIR__/scripts/update-and-start.sh
ExecStop=__TIPI_DIR__/scripts/stop.sh
RemainAfterExit=yes
Restart=on-failure
RestartSec=30
TimeoutStartSec=900
TimeoutStopSec=90

[Install]
WantedBy=multi-user.target
